VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# Admin: create this user in Firebase Console → Authentication → Email/Password
# Then sign in at /admin/login

# Google Reviews — direct write-review link (opens Google sign-in → review form)
VITE_GOOGLE_REVIEWS_URL=https://g.page/r/CfAt1kzwMqi_EAE/review

# Required to SHOW reviews on homepage (Google Places API — not Firebase)
# 1. Google Cloud Console → Enable "Places API (New)"
# 2. Create API key → restrict to Places API (New) only
# 3. Paste key below and restart npm run dev
VITE_GOOGLE_MAPS_API_KEY=your-maps-api-key
VITE_GOOGLE_PLACE_ID=ChIJI96jbuIBGTkR8C3WTPAyqL8
